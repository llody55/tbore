server_addr: "your_server_ip"
server_port: 7835
token: "your_secure_secret_token_here"
host_key: ""
project: ""
region: ""
health_check_interval: 30
tunnels:
  - name: "web-service"
    local_ip: "127.0.0.1"
    local_port: 8080
    remote_port: 8501
    timeout: 300
  - name: "ssh-tunnel"
    local_ip: "192.168.1.10"
    local_port: 22
    remote_port: 0
    timeout: 300